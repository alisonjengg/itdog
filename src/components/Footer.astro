---
const serviceLinks = ['Web Design', 'IT Infrastructure', 'Cloud Solutions', 'Digital Strategy'];
const companyLinks = ['About Us', 'Our Team', 'Careers', 'Blog'];
const resourceLinks = ['Documentation', 'Case Studies', 'Privacy Policy', 'Terms of Service'];
---

<footer class="footer">
  <div class="footer-top">
    <div class="footer-brand">
      <span class="footer-logo">IT Dog</span>
      <p class="footer-tagline">
        Empowering SMEs with smart IT solutions.<br />Web design, cloud,
        infrastructure — all under one roof.
      </p>
      <div class="footer-socials">
        <a href="#" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="#" aria-label="Twitter">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
        </a>
        <a href="#" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href="#" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
      </div>
    </div>
    <div class="footer-links">
      <div class="footer-col">
        <h4 class="footer-col-title">Services</h4>
        {serviceLinks.map((link) => (
          <a href="#" class="footer-link">{link}</a>
        ))}
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">Company</h4>
        {companyLinks.map((link) => (
          <a href="#" class="footer-link">{link}</a>
        ))}
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">Resources</h4>
        {resourceLinks.map((link) => (
          <a href="#" class="footer-link">{link}</a>
        ))}
      </div>
    </div>
  </div>
  <div class="footer-divider"></div>
  <div class="footer-bottom">
    <span class="copyright">&copy; 2026 IT Dog. All rights reserved.</span>
    <span class="hours">Mon — Fri  9:00 — 18:00</span>
  </div>
</footer>

<style>
  .footer {
    display: flex;
    flex-direction: column;
    gap: 48px;
    padding: 60px 120px;
    background-color: var(--card);
  }

  .footer-top {
    display: flex;
    gap: 80px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 300px;
    flex-shrink: 0;
  }

  .footer-logo {
    font-family: var(--font-primary);
    font-size: 24px;
    font-weight: 700;
    color: var(--foreground);
  }

  .footer-tagline {
    font-family: var(--font-secondary);
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted-foreground);
  }

  .footer-socials {
    display: flex;
    gap: 12px;
  }

  .footer-socials a {
    color: var(--muted-foreground);
    transition: color 0.2s;
  }

  .footer-socials a:hover {
    color: var(--foreground);
  }

  .footer-links {
    display: flex;
    gap: 60px;
    flex: 1;
    justify-content: flex-end;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-col-title {
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    color: var(--foreground);
  }

  .footer-link {
    font-family: var(--font-secondary);
    font-size: 13px;
    color: var(--muted-foreground);
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--foreground);
  }

  .footer-divider {
    height: 1px;
    background-color: var(--border);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .copyright,
  .hours {
    font-family: var(--font-secondary);
    font-size: 12px;
    color: var(--muted-foreground);
  }

  @media (max-width: 768px) {
    .footer {
      padding: 40px 24px;
    }

    .footer-top {
      flex-direction: column;
      gap: 40px;
    }

    .footer-brand {
      width: 100%;
    }

    .footer-links {
      justify-content: flex-start;
      gap: 32px;
      flex-wrap: wrap;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
    }
  }
</style>
